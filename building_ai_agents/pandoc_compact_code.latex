% Pandoc LaTeX template fragment to make code blocks more compact
\usepackage{etoolbox}

% Pandoc places code blocks inside the Shaded environment.
% Apply compact spacing there rather than patching low-level verbatim internals.
\BeforeBeginEnvironment{Shaded}{\vspace{-0.55em}}
\AtBeginEnvironment{Shaded}{%
  \setlength{\parskip}{0pt}%
  \setlength{\parindent}{0pt}%
  \footnotesize%
  \linespread{0.96}\selectfont%
}
\AfterEndEnvironment{Shaded}{\vspace{-0.55em}}
