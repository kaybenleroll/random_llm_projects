# SKIKK Thor 16 sysadmin task runner
# Run `just` or `just --list` to see available recipes

default:
    @just --list

# ─── Health Checks ───────────────────────────────────────────────────────────

# Quick 5-item health check (~2 min): failed units, GPU PM, ASPM, D3cold storm, root FS
health-quick:
    @echo "=== Q1: Failed systemd units ==="
    systemctl --failed
    @echo ""
    @echo "=== Q2: GPU runtime PM fix ==="
    grep NVreg_DynamicPowerManagement /etc/modprobe.d/nvidia-power.conf /etc/modprobe.d/nvidia.conf 2>/dev/null
    @echo ""
    @echo "=== Q3: PCIe ASPM policy ==="
    grep -o 'pcie_aspm[^ ]*' /proc/cmdline
    @echo ""
    @echo "=== Q4: GPU D3cold storm (last 10 min) ==="
    sudo dmesg --since "10 minutes ago" | grep -c 'nvidia.*pm_runtime_work\|nvidia.*D3cold\|nvidia.*NVPCF' || true
    @echo ""
    @echo "=== Q5: Root filesystem headroom ==="
    df -h / /data 2>/dev/null

# Full health check: runs health-quick plus GPU firmware, storage, networking, thermal, processes, mounts
health-full: health-quick
    @echo ""
    @echo "=== 3A: ACPI DSDT OEM revision ==="
    sudo python3 -c "import struct; hdr=open('/sys/firmware/acpi/tables/DSDT','rb').read(36); rev=struct.unpack('<I',hdr[24:28])[0]; print(hex(rev))"
    @echo ""
    @echo "=== 3A: GRUB cmdline ==="
    cat /proc/cmdline
    @echo ""
    @echo "=== 3A: Kernel messages (errors/warnings, filtered) ==="
    sudo dmesg | grep -E 'error|fail|warn' | grep -v -E 'ite_8291|Bluetooth: hci|acpi-cpufreq|ACPI: \\_SB' | tail -30
    @echo ""
    @echo "=== 3B: GPU firmware mode ==="
    nvidia-smi --query-gpu=name,driver_version,persistence_mode --format=csv,noheader
    @echo ""
    @echo "=== 3B: D3cold storm check (last 1 hour) ==="
    sudo journalctl -k --since "1 hour ago" | grep -c 'pm_runtime_work\|NVPCF\|D3cold' || true
    @echo ""
    @echo "=== 3B: GPE07 rate ==="
    sudo cat /sys/kernel/debug/acpi/gpe_info 2>/dev/null | grep -i 'gpe07\|GPE07' || echo "(gpe_info not available)"
    @echo ""
    @echo "=== 3C: NVMe SMART summary ==="
    sudo /usr/sbin/smartctl -a /dev/nvme0n1 | grep -E 'Model|Serial|Temperature|Available Spare|Unsafe Shutdowns|Media and Data|Power On Hours'
    sudo /usr/sbin/smartctl -a /dev/nvme1n1 | grep -E 'Model|Serial|Temperature|Available Spare|Unsafe Shutdowns|Media and Data|Power On Hours'
    @echo ""
    @echo "=== 3C: Filesystem usage ==="
    df -h / /data
    @echo ""
    @echo "=== 3D: NIC driver state (r8125/r8169 blacklisted) ==="
    @lsmod | grep -E 'r8125|r8169' && echo "WARNING: NIC driver loaded — blacklist not effective" || echo "r8125/r8169 not loaded (expected)"
    @echo ""
    @echo "=== 3E: DIMM temperatures ==="
    sensors | grep -A5 -i 'spd\|dimm\|ddr' || echo "(no DIMM sensor data)"
    @echo ""
    @echo "=== 3E: CPU temperature ==="
    sensors | grep -E 'Tctl|Tdie|Package'
    @echo ""
    @echo "=== 3E: GPU temperature ==="
    nvidia-smi --query-gpu=temperature.gpu --format=csv,noheader
    @echo ""
    @echo "=== 3F: Zombie count ==="
    ps aux | awk '$8=="Z"' | wc -l
    @echo ""
    @echo "=== 3F: Podman containers ==="
    podman ps -a
    @echo ""
    @echo "=== 3G: rclone mounts ==="
    mount | grep rclone || echo "(no rclone mounts)"
    systemctl list-units --type=service --no-pager 2>/dev/null | grep -i rclone || echo "(no rclone systemd units found)"

# Run all health checks and save timestamped output to logs/
health-log:
    @mkdir -p logs
    @just health-all 2>&1 | tee logs/health-$(date +%Y%m%d-%H%M%S).txt

# Run all health checks (9 domains). Requires sudo for some sections. Use `just health-log` to capture to file.
health-all:
    @mkdir -p logs .scratch
    @echo "=== [1/9] Core hardware & firmware ==="
    @just health-full
    @echo ""
    @echo "=== [2/9] Boot, timers & coredumps ==="
    @just health-boot
    @echo ""
    @echo "=== [3/9] NVMe SMART ==="
    @just smart-check 2>&1 | tee .scratch/smart-check.txt
    @echo ""
    @echo "=== [4/9] Security (firewall + SSH) ==="
    @just security-check 2>&1 | tee .scratch/security-check.txt
    @echo ""
    @echo "=== [5/9] Package hygiene ==="
    @just health-packages
    @echo ""
    @echo "=== [6/9] Container hygiene ==="
    @just health-containers
    @echo ""
    @echo "=== [7/9] Home directory cruft ==="
    @just health-cruft
    @echo ""
    @echo "=== [8/9] Log health ==="
    @just health-logs
    @echo ""
    @echo "=== [9/9] Network health ==="
    @just health-network
    @echo ""
    @echo "=== health-all complete ==="

# Boot health: uptime, boot time, installed kernels, pending reboot, coredumps, failed timers
health-boot:
    @echo "=== Uptime and load ==="
    uptime
    @echo ""
    @echo "=== Boot time ==="
    systemd-analyze
    @echo ""
    @echo "=== Slow boot units (top 10) ==="
    systemd-analyze blame | head -10
    @echo ""
    @echo "=== Installed kernels ==="
    ls /boot/vmlinuz-* | sort -V
    @echo ""
    @echo "=== Pending reboot ==="
    @[ -f /var/run/reboot-required ] && cat /var/run/reboot-required || echo "none"
    @echo ""
    @echo "=== Coredumps ==="
    coredumpctl list 2>/dev/null | tail -10 | grep -q '.' && coredumpctl list 2>/dev/null | tail -10 || echo "none"
    @echo ""
    @echo "=== Failed/missed systemd timers ==="
    systemctl list-timers --all --no-pager | grep -E 'n/a|failed' || echo "all timers OK"

# Package hygiene: upgradable packages, purge candidates, disabled snap revisions
health-packages:
    @echo "=== Upgradable packages ==="
    apt list --upgradable 2>/dev/null | grep -v '^Listing' || echo "none"
    @echo ""
    @echo "=== Security updates ==="
    apt list --upgradable 2>/dev/null | grep -i security || echo "none"
    @echo ""
    @echo "=== Purge candidates (removed packages with leftover config) ==="
    dpkg -l | grep '^rc' | awk '{print $2}' || echo "none"
    @echo ""
    @echo "=== Disabled snap revisions ==="
    snap list --all 2>/dev/null | grep disabled || echo "none"

# Container hygiene: disk usage, dangling images, stopped containers
health-containers:
    @echo "=== Podman system disk usage ==="
    podman system df
    @echo ""
    @echo "=== Dangling images ==="
    podman images --filter dangling=true 2>/dev/null || echo "none"
    @echo ""
    @echo "=== Exited containers ==="
    podman ps -a --filter status=exited 2>/dev/null

# Home directory cruft: cache, downloads, trash, large files (>500 MB)
health-cruft:
    @echo "=== Home directory sizes ==="
    du -sh /home/mcooney/Downloads /home/mcooney/.cache /home/mcooney/.local/share/Trash /home/mcooney/.local/share/containers 2>/dev/null | sort -h
    @echo ""
    @echo "=== Files over 500 MB in home (local filesystem only) ==="
    find /home/mcooney -xdev -maxdepth 6 -type f -size +500M \
        -not -path '*/snap/*' \
        -not -path '*/\.local/share/containers/*' \
        -printf '%s\t%p\n' 2>/dev/null | sort -rn | head -15 | \
        numfmt --to=iec --field=1 2>/dev/null || echo "(none found)"

# Log health: recent error counts, error trend, failed SSH login attempts
health-logs:
    @echo "=== Journal errors (last 24h, filtered) ==="
    journalctl -p err --since "24 hours ago" --no-pager -q 2>/dev/null \
        | grep -v -E 'ite_8291|GPE07|NVreg|enp5s0' | tail -30 || true
    @echo ""
    @echo "=== Error count last 7 days (excl. known noise) ==="
    journalctl -p err --since "7 days ago" --no-pager -q 2>/dev/null \
        | grep -v -E 'ite_8291|GPE07|NVreg|enp5s0' | wc -l || echo "0"
    @echo ""
    @echo "=== r8125 ESD recovery events (last 7 days, expected 0 — r8125 blacklisted) ==="
    journalctl -p err --since "7 days ago" -k --no-pager -q 2>/dev/null \
        | grep -c 'enp5s0.*pci link is down' || echo "0"
    @echo ""
    @echo "=== Failed SSH login attempts (last 24h) ==="
    journalctl --since "24 hours ago" -u ssh --no-pager -q 2>/dev/null \
        | grep -c 'Failed password\|Invalid user' || echo "0"

# Network health: active connections, WiFi signal, DNS check, ethernet state
health-network:
    @echo "=== Active connections ==="
    nmcli connection show --active 2>/dev/null || ip route show
    @echo ""
    @echo "=== WiFi networks visible (signal) ==="
    nmcli -f SSID,SIGNAL,BARS device wifi list 2>/dev/null | head -6 || echo "(not available)"
    @echo ""
    @echo "=== DNS resolution ==="
    resolvectl query google.com 2>/dev/null | head -5 || nslookup google.com 2>/dev/null | head -6 || echo "DNS check failed"
    @echo ""
    @echo "=== Ethernet state (r8125/r8169 blacklisted — NIC unused) ==="
    @lsmod | grep -E 'r8125|r8169' && echo "WARNING: NIC driver loaded — blacklist not effective" || echo "NIC drivers not loaded (expected)"

# Capture key metrics as a single timestamped line for trend tracking
health-snapshot:
    @mkdir -p logs
    @[ -f logs/health-metrics.tsv ] || echo -e "timestamp\tdisk_pct\tdimm1_temp\tzombies\tfailed_units\tgpu_pm" > logs/health-metrics.tsv
    @echo -e "$(date +%Y-%m-%dT%H:%M:%S)\t$(df / | awk 'NR==2{print $5}' | tr -d '%')\t$(sensors 2>/dev/null | grep -A1 'DIMM 1' | grep 'temp1' | awk '{print $2}' | tr -d '+°C' || echo unknown)\t$(ps aux | awk '{print $8}' | grep -c '^Z' || echo 0)\t$(systemctl --failed --no-legend 2>/dev/null | wc -l | tr -d ' ')\t$(grep -h NVreg_DynamicPowerManagement /etc/modprobe.d/nvidia-power.conf 2>/dev/null | head -1 | grep -o '0x[0-9a-fA-F]*' || echo unknown)" >> logs/health-metrics.tsv
    @echo "Snapshot saved. Current metrics:"
    @tail -2 logs/health-metrics.tsv | column -t -s $'\t'

# ─── GPU / Power ──────────────────────────────────────────────────────────────

# Show current ASPM policy from /proc/cmdline and live kernel parameter
aspm-status:
    @echo "=== /proc/cmdline (ASPM flags) ==="
    grep -o 'pcie_aspm[^ ]*' /proc/cmdline
    @echo ""
    @echo "=== Live kernel ASPM policy ==="
    cat /sys/module/pcie_aspm/parameters/policy

# Show NVreg_DynamicPowerManagement value across all modprobe.d files
gpu-pm-status:
    grep NVreg_DynamicPowerManagement /etc/modprobe.d/nvidia-power.conf /etc/modprobe.d/nvidia.conf 2>/dev/null

# Show CPU, GPU, and DIMM temperatures from sensors
temps:
    @echo "=== CPU ==="
    sensors | grep -E 'Tctl|Tdie|Package'
    @echo ""
    @echo "=== GPU ==="
    nvidia-smi --query-gpu=temperature.gpu --format=csv,noheader
    @echo ""
    @echo "=== DIMMs ==="
    sensors | grep -A5 -i 'spd\|dimm\|ddr' || echo "(no DIMM sensor data)"

# ─── Fan Profiles ─────────────────────────────────────────────────────────────

# Switch TCC fan profile to performance (thor_gaming)
fan-performance:
    bash scripts/switch_profile.sh thor_gaming

# Switch TCC fan profile to balanced (thor_balanced)
fan-balanced:
    bash scripts/switch_profile.sh thor_balanced

# Switch TCC fan profile to TUXEDO default (balanced fan curve, no overboost)
fan-auto:
    bash scripts/switch_profile.sh __default_custom_profile__

# ─── Storage ──────────────────────────────────────────────────────────────────

# Identify storage consumers under /home and /var
disk-usage:
    du -sh /home/* /var/* 2>/dev/null | sort -h

# Run SMART diagnostics on both NVMe drives
# Note: requires Bash(sudo /usr/sbin/smartctl**) in CC settings allowlist
smart-check:
    sudo /usr/sbin/smartctl -a /dev/nvme0n1
    sudo /usr/sbin/smartctl -a /dev/nvme1n1

# ─── Dotfiles ─────────────────────────────────────────────────────────────────

# Show pending chezmoi changes
dotfiles-diff:
    chezmoi diff

# Apply chezmoi dotfile changes
dotfiles-apply:
    chezmoi apply

# Pull upstream and apply chezmoi dotfile changes
dotfiles-update:
    chezmoi update

# ─── Maintenance & Security ──────────────────────────────────────────────────

# Show all listening TCP and UDP sockets with owning processes
ports:
    @echo "=== Listening TCP ==="
    ss -tlnp
    @echo ""
    @echo "=== Listening UDP ==="
    ss -ulnp

# Update package lists and upgrade all installed packages
pkg-upgrade:
    sudo apt update && sudo apt upgrade -y
    sudo apt autoremove -y

# Purge config files left by removed packages (rc state in dpkg)
pkg-purge:
    @echo "=== Packages in rc state ==="
    dpkg -l | grep '^rc' | awk '{print $2}'
    dpkg -l | grep '^rc' | awk '{print $2}' | xargs sudo apt-get purge -y

# Remove all disabled snap revisions to reclaim disk space
snap-clean:
    snap list --all | awk '/disabled/{print $1, $3}' | while read name rev; do \
        sudo snap remove "$$name" --revision="$$rev"; \
    done
    sudo snap set system refresh.retain=2

# Show firewall status, external-facing listeners, and SSH hardening config
security-check:
    @echo "=== UFW Status ==="
    sudo ufw status verbose
    @echo ""
    @echo "=== External-facing TCP listeners ==="
    ss -tlnp | grep -v '127\.' | grep -v '\[::1\]'
    @echo ""
    @echo "=== SSH config ==="
    grep -E 'PasswordAuthentication|PermitRootLogin|Port' /etc/ssh/sshd_config

# Trim systemd journal to last 30 days and show current disk usage
journal-trim:
    sudo journalctl --vacuum-time=30d
    sudo journalctl --disk-usage

# ── Stremio ──────────────────────────────────────────────────────────────────

# Start Stremio server container and open in Chrome app mode
stremio:
    @bash /home/mcooney/sysadmin_files/utilities/stremio-launch.sh

# Start Stremio server container only (no browser)
stremio-server:
    @podman run -d --name stremio-server --restart unless-stopped \
        -p 11470:11470 \
        -v $(echo $HOME)/.stremio-server:/root/.stremio-server:Z \
        docker.io/sleeyax/stremio-streaming-server:latest

# Stop and remove Stremio server container
stremio-stop:
    @podman rm -f stremio-server 2>/dev/null || true
    @echo "Stremio server stopped"
